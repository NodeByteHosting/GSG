{
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "include": [
      "**/*.ts",
      "scripts/**/*.mjs"
    ],
    "exclude": [
      ".git/**",
      ".github/**"
    ]
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    },
    "include": [
      "**/*.ts",
      "scripts/**/*.mjs"
    ],
    "exclude": [
      ".git/**",
      ".github/**"
    ]
  }
}